# Local Edge Function env — passed to `supabase functions serve --env-file ../.env.local`.
# Copy to .env.local and fill. Supabase injects SUPABASE_URL / SUPABASE_ANON_KEY /
# SUPABASE_SERVICE_ROLE_KEY / SUPABASE_DB_URL automatically, so they are NOT listed here.

# Inter-function calls (oauth-callback → backfill) and OAuth redirect_uri base.
FUNCTIONS_BASE_URL=http://localhost:54321/functions/v1

# SPA origin: CORS allow-origin for browser→function calls AND where oauth-callback redirects
# the cadre back after consent. In production set this to the deployed frontend origin.
FRONTEND_ORIGIN=http://localhost:5173

# Anonymization key (any strong value for local dev).
COMMENTER_HASH_KEY=local-dev-hash-key-change-me

# LLM + embeddings. Any non-empty value works against the local mock (the key is not checked by
# the mock, but the code requires it to be present). Use real keys only to test against real APIs.
OPENROUTER_API_KEY=mock-openrouter-key
GEMINI_EMBEDDING_API_KEY=mock-gemini-key

# --- External API endpoints (prod/local differ ONLY here; see backend/supabase/shared/endpoints.ts) ---
# Leave ALL of these UNSET in production → the real Meta/Google/OpenRouter/Gemini endpoints apply.
# Set locally → point at backend/supabase/mocks/server.ts (make mock) for a full offline pipeline.
# API bases are called BY the Edge Functions (in the edge-runtime container) → host.docker.internal.
# Dialog URLs are opened BY the browser (host) → localhost. The mock listens on both.
GRAPH_API_BASE=http://host.docker.internal:9100/meta/graph
YOUTUBE_API_BASE=http://host.docker.internal:9100/youtube/v3
GOOGLE_TOKEN_URL=http://host.docker.internal:9100/google/token
OPENROUTER_BASE=http://host.docker.internal:9100/openrouter/v1
GEMINI_API_BASE=http://host.docker.internal:9100/gemini/v1beta
FACEBOOK_DIALOG_URL=http://localhost:9100/meta/dialog/oauth
GOOGLE_AUTH_URL=http://localhost:9100/google/auth

# Platform OAuth apps (only needed to exercise live onboarding/ingestion locally).
IG_APP_ID=
IG_APP_SECRET=
IG_WEBHOOK_VERIFY_TOKEN=local-verify-token
YT_CLIENT_ID=
YT_CLIENT_SECRET=
# Optional: bypass per-channel Vault token resolution during local YouTube tests.
YT_ACCESS_TOKEN_OVERRIDE=
# Release gate (Principle VII): YouTube ingestion is OFF unless this is exactly "true".
# Do NOT set true in production until the quota audit is approved (docs/quota-audit.md).
YT_INGEST_ENABLED=false
