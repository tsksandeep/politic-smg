# Local Edge Function env — loaded by the edge-runtime container (env_file: .env.local) and by the
# media worker. Copy to .env.local and fill. The platform injects SUPABASE_URL / SUPABASE_ANON_KEY /
# SUPABASE_SERVICE_ROLE_KEY / SUPABASE_DB_URL automatically, so they are NOT listed here.

# SPA origin: CORS allow-origin for browser→function calls (war-room → alert-triage / detection-settings).
# In production set this to the deployed frontend origin.
FRONTEND_ORIGIN=http://localhost:5173

# --- Keyed secrets (any strong value for local dev) ------------------------------------------------
# Comment-author hashing at ingest (Principle III). Rotating it breaks historical hash continuity.
COMMENTER_HASH_KEY=local-dev-hash-key-change-me
# Derives/verifies node.token_hash; raw node tokens are shown once at register and never stored.
NODE_TOKEN_KEY=local-dev-node-token-key-change-me
# Signs/validates the tenant enrolment code a node redeems at first run (node-register).
NODE_ENROLMENT_SECRET=local-dev-enrolment-secret-change-me

# ===========================================================================================
# LLM + EMBEDDINGS — three interchangeable modes, selected by env only (no code change):
#   (A) MOCK (default below)  — fully offline, deterministic; OPENROUTER_BASE + VERTEX_EMBEDDINGS_URL
#       point at the mock (make mock / the `mock` compose service); EMBEDDINGS_PROVIDER stays "vertex".
#   (B) LOCAL real models     — an OpenAI-compatible server (e.g. LM Studio @ :1234) for BOTH chat
#       and embeddings. See "Option B" below.
#   (C) CLOUD                 — hosted OpenRouter (real key) + Vertex AI embeddings (service account).
# ===========================================================================================

# LLM key. Mock ignores it but the code requires it present for hosted OpenRouter. Local servers
# (Option B) need no key. Cloud: set your real OpenRouter key.
OPENROUTER_API_KEY=mock-openrouter-key
# JSON mode: "json_object" (OpenRouter/Gemini) or "none" for local servers (LM Studio) that reject it.
# LLM_RESPONSE_FORMAT=none

# Embeddings provider: "vertex" (mock/cloud, Vertex :predict shape) or "openai" (local /v1/embeddings).
EMBEDDINGS_PROVIDER=vertex
# Vertex auth (modes A/C): a static token short-circuits minting locally (mock ignores it); for cloud
# leave VERTEX_ACCESS_TOKEN empty and provide a service account to mint tokens.
VERTEX_ACCESS_TOKEN=mock-vertex-token
# VERTEX_SA_EMAIL=embeddings@<project>.iam.gserviceaccount.com
# VERTEX_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Option B: LOCAL real models via an OpenAI-compatible server (LM Studio). Uncomment + set
#     OPENROUTER_BASE / EMBEDDINGS_BASE to host.docker.internal:1234, and serve LM Studio on the local
#     network (not just 127.0.0.1) so the container can reach it. Embedding dim MUST be 768 (vector(768)).
# OPENROUTER_MODEL=google/gemma-4-31b-qat
# LLM_RESPONSE_FORMAT=none
# EMBEDDINGS_PROVIDER=openai
# EMBEDDINGS_BASE=http://host.docker.internal:1234/v1
# EMBEDDINGS_MODEL=text-embedding-embeddinggemma-300m   # 768-dim, matches vector(768)
# EMBEDDINGS_API_KEY=        # not needed for LM Studio

# --- External inference endpoints (prod/local differ ONLY here) ------------------------------------
# Local → point at backend/supabase/mocks/server.ts (the `mock` service) for a fully offline pipeline.
# Production: leave OPENROUTER_BASE unset (its built-in default applies); VERTEX_EMBEDDINGS_URL has NO
# default — it is project/region-specific and must be set explicitly (asia-south1 for IN-DPDP residency).
OPENROUTER_BASE=http://host.docker.internal:9100/openrouter/v1
VERTEX_EMBEDDINGS_URL=http://host.docker.internal:9100/vertex/v1/models/gemini-embedding-001:predict
# Prod embeddings URL (example):
# VERTEX_EMBEDDINGS_URL=https://asia-south1-aiplatform.googleapis.com/v1/projects/<PROJECT>/locations/asia-south1/publishers/google/models/gemini-embedding-001:predict

# --- enrich queue tuning (pgmq enrich_jobs) -------------------------------------------------------
# Batch claimed per run, per-message visibility timeout (s), max delivery attempts before a poison
# message moves to enrich_jobs_dlq. Defaults are fine for local dev.
ENRICH_BATCH=100
ENRICH_VT_SECONDS=120
ENRICH_MAX_READS=5
