# Local Edge Function env — passed to `supabase functions serve --env-file ../.env.local`.
# Copy to .env.local and fill. Supabase injects SUPABASE_URL / SUPABASE_ANON_KEY /
# SUPABASE_SERVICE_ROLE_KEY / SUPABASE_DB_URL automatically, so they are NOT listed here.

# Inter-function calls (oauth-callback → backfill).
FUNCTIONS_BASE_URL=http://localhost:54321/functions/v1

# SPA origin: CORS allow-origin for browser→function calls (incl. the SPA's POST to oauth-callback
# after the Nango Connect flow). In production set this to the deployed frontend origin.
FRONTEND_ORIGIN=http://localhost:5173

# Anonymization key (any strong value for local dev).
COMMENTER_HASH_KEY=local-dev-hash-key-change-me

# ===========================================================================================
# LLM + EMBEDDINGS — three interchangeable modes, selected by env only (no code change):
#   (A) MOCK (default below)  — fully offline, deterministic; OPENROUTER_BASE + VERTEX_EMBEDDINGS_URL
#       point at the mock; EMBEDDINGS_PROVIDER stays "vertex".
#   (B) LOCAL real models      — an OpenAI-compatible server (e.g. LM Studio @ :1234) for BOTH chat
#       and embeddings. Set the block marked "Option B" below.
#   (C) CLOUD                  — hosted OpenRouter (real key) + Vertex AI embeddings (service account).
# ===========================================================================================

# LLM key. Mock ignores it but the code requires it present for hosted OpenRouter. Local servers
# (Option B) need no key. Cloud: set your real OpenRouter key.
OPENROUTER_API_KEY=mock-openrouter-key
# JSON mode: "json_object" (OpenRouter/Gemini) or "none" for local servers (LM Studio) that reject it.
# LLM_RESPONSE_FORMAT=none

# Embeddings provider: "vertex" (mock/cloud, Vertex :predict shape) or "openai" (local /v1/embeddings).
EMBEDDINGS_PROVIDER=vertex
# Vertex auth (modes A/C): a static token short-circuits minting locally (mock ignores it); for cloud
# leave VERTEX_ACCESS_TOKEN empty and provide a service account to mint tokens.
VERTEX_ACCESS_TOKEN=mock-vertex-token
# VERTEX_SA_EMAIL=embeddings@<project>.iam.gserviceaccount.com
# VERTEX_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Option B: LOCAL real models via an OpenAI-compatible server (LM Studio). Uncomment + set
#     OPENROUTER_BASE / EMBEDDINGS_BASE to host.docker.internal:1234 (see endpoints below), and make
#     sure LM Studio is serving on the local network (not just 127.0.0.1) so the container can reach it.
# OPENROUTER_MODEL=google/gemma-4-31b-qat
# LLM_RESPONSE_FORMAT=none
# EMBEDDINGS_PROVIDER=openai
# EMBEDDINGS_BASE=http://host.docker.internal:1234/v1
# EMBEDDINGS_MODEL=text-embedding-embeddinggemma-300m   # 768-dim, matches vector(768)
# EMBEDDINGS_API_KEY=        # not needed for LM Studio

# --- External API endpoints (prod/local differ ONLY here; see backend/supabase/shared/endpoints.ts) ---
# Local → point at backend/supabase/mocks/server.ts (make mock) for a full offline pipeline.
# In production set the REAL endpoints (Meta/Google/OpenRouter unset → their built-in defaults apply;
# VERTEX_EMBEDDINGS_URL has NO default — it is project/region-specific and must be set explicitly).
# These are the APP's direct API calls, made BY the Edge Functions (in the edge-runtime container)
# → host.docker.internal. (Cadre OAuth dialog + token URLs are NOT here — they are configured in
# Nango's provider overrides: backend/docker/nango/providers.yaml. GOOGLE_TOKEN_URL below is used by
# the app only to mint a Vertex embeddings token, not for cadre OAuth.)
GRAPH_API_BASE=http://host.docker.internal:9100/meta/graph
YOUTUBE_API_BASE=http://host.docker.internal:9100/youtube/v3
GOOGLE_TOKEN_URL=http://host.docker.internal:9100/google/token
OPENROUTER_BASE=http://host.docker.internal:9100/openrouter/v1
VERTEX_EMBEDDINGS_URL=http://host.docker.internal:9100/vertex/v1/models/gemini-embedding-001:predict
# Prod embeddings URL (example):
# VERTEX_EMBEDDINGS_URL=https://asia-south1-aiplatform.googleapis.com/v1/projects/<PROJECT>/locations/asia-south1/publishers/google/models/gemini-embedding-001:predict

# Self-hosted Nango — manages cadre OAuth + token storage/refresh (replaces the old Vault/token
# plumbing). Functions reach it in-network at nango-server:3003; the browser uses VITE_NANGO_HOST.
# Local: the Secret Key is published to the app_config table by nango-init (turnkey).
# Prod: set NANGO_HOST to the deployed Nango URL and NANGO_SECRET_KEY to its env Secret Key, and
#       register the instagram/youtube integrations in the Nango dashboard with real client creds.
NANGO_HOST=http://nango-server:3003
# NANGO_SECRET_KEY=        # prod only; local reads it from app_config

# Instagram comment webhook (separate from Nango — Meta calls this directly; HMAC-verified).
IG_APP_SECRET=
IG_WEBHOOK_VERIFY_TOKEN=local-verify-token
# Optional escape hatch: bypass per-channel Nango token resolution during local YouTube tests.
YT_ACCESS_TOKEN_OVERRIDE=
# Release gate (Principle VII): YouTube ingestion is OFF unless this is exactly "true".
# Do NOT set true in production until the quota audit is approved (docs/quota-audit.md).
YT_INGEST_ENABLED=false

# --- analyze-comments queue tuning (pgmq analyze_jobs; see migrations/0014_analyze_queue.sql) ---
# Batch claimed per run, per-message visibility timeout (s), and max delivery attempts before a
# poison message is moved to analyze_jobs_dlq. Defaults are fine for local dev.
ANALYZE_BATCH=100
ANALYZE_VT_SECONDS=120
ANALYZE_MAX_READS=5
