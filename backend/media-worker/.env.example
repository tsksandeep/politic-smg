# media-worker env — copy to .env (never commit .env). Secrets come from Supabase Vault in prod.

# --- required ---
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=

# --- OCR/ASR provider: gemini (hosted, default) | local (tesseract + faster-whisper) ---
MEDIA_PROVIDER=gemini
OPENROUTER_API_KEY=
OPENROUTER_MODEL_VISION=google/gemini-2.5-flash
OPENROUTER_MODEL_AUDIO=google/gemini-2.5-flash

# --- transcript embedding: none (default, NULL) | vertex | openai ---
EMBEDDINGS_PROVIDER=none
# vertex (needs a static short-lived token; SA-JWT minting lives in shared/embeddings.ts):
# VERTEX_EMBEDDINGS_URL=
# VERTEX_ACCESS_TOKEN=
# openai-compatible (e.g. LM Studio):
# EMBEDDINGS_BASE=http://host.docker.internal:1234/v1

# --- tuning ---
MEDIA_BATCH=8
POLL_INTERVAL_SECONDS=5
MEDIA_VT_SECONDS=120
MEDIA_MAX_READS=5
VIDEO_FRAME_OCR=true
TESSERACT_LANG=eng+tam
WHISPER_MODEL=small
